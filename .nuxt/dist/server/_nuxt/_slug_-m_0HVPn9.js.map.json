{"file":"_slug_-m_0HVPn9.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAUO,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,eAAW,MAAA,CAAA,CAAA,WAAA;AACGC,oBAAA,QAAA,WAAX,YAAO;;;UAEL,OAAM;AAAA,UAAuC,KAAK,QAAQ;AAAA,UAAY,KAAK,QAAQ;AAAA,QAAA;uJAG3BC,eAAA,QAAQ,QAAQ,2DACvBA,eAAA,IAAA,KAAK,QAAQ,SAAS,EAAE,mBAAkB,OAAA,CAAA,4EAErCA,eAAA,QAAQ,OAAO;YAItE,QAAQ,QAAQ,SAAM,GAAA;;;YACf,UAAU,QAAQ;AAAA,UAAA;;;;;;;;;;;;;;;;;;;;;;;;;;ACnB1C,UAAM,QAAQ;AAKd,UAAM,WAAW,IAAI,EAAE;AACvB,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,UAAU,IAAI,EAAE;AACtB,UAAM,UAAU,IAAI,EAAE;AACtB,UAAM,UAAU,IAAI,EAAE;AACtB,UAAM,aAAa,IAAI,KAAK;AAC5B,UAAM,iBAAiB,IAAI,KAAK;AAChC,UAAM,YAAY,IAAmB,IAAI;AAEzC,UAAM,EAAE,MAAM,UAAU,SAAS,QAAA,KAAY,CAAA,QAAA,SAAA,IAAAC,iBAAA,MAAM;AAAA,MACjD,MAAM,YAAY,MAAM,WAAW;AAAA,MACnC,MAAM,oBAAoB,MAAM,WAAW;AAAA,MAAA;AAAA;AAAA,IAAA,CAC7C;AAE+C;AAAA,MAC7C;AAAA,IAOF;;;uBA6DWJ,eAAAC,WAAA,EAAA,OAAM,QAAA,GAAO,MAAA,CAAA,8MAG8EE,eAAAE,MAAA,QAAA,GAAU,UAAM,CAAA;UAGvG,QAAA,cAAY;yQAIDA,MAAA,QAAA,CAAQ,iLACRA,MAAA,KAAA,CAAK,qMAEPA,MAAA,OAAA,CAAO,6WAEZA,MAAA,OAAA,CAAO;YAMTA,MAAA,cAAA,GAAc;;;;;uIAKwCA,MAAA,UAAA,CAAU,IAAA,cAAA,qBAClEA,MAAA,UAAA,IAAU,kBAAA,cAAA;YAEHA,MAAA,OAAA,GAAO;iFAA8CA,MAAA,OAAA,CAAO,CAAA,SAAA;AAAA;;;;;;;UASnEA,MAAA,OAAA,GAAO;;iBAGFA,MAAA,QAAA,KAAYA,MAAA,QAAA,EAAS,SAAM,GAAA;;AACzB,cAAAC,mBAAA,0BAAA,EAAA,UAAUD,MAAA,QAAA,EAAA,GAAQ,MAAA,OAAA,CAAA;;;;;;;;;;;;;;;;;;;;AC7HxC,UAAM,QAAQ,SAAA;AACd,UAAM,OAAO,SAAS,MAAM,OAAO,MAAM,OAAO,QAAQ,EAAE,CAAC;AAC3D,UAAM,EAAE,MAAM,aAAA,KAAiB,CAAA,QAAA,SAAA,IAAAD,iBAAA,MAAM,aAAa,iBAAiB,uBAAuB,CAAA;AAG1F,UAAM,EAAE,MAAM,QAAA,KAAY,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAM;AAAA,MAAa,MAAM,WAAW,KAAK,KAAK;AAAA,MAAI,MAAM,yBAAyB,KAAK,KAAK;AAAA,MAAA;AAAA;AAAA,KAAC;AAGtH,UAAM,EAAE,MAAM,YAAA,IAAgB,aAAa,uBAAuB,wBAAwB,EAAE,MAAM,MAAM;AAExG,UAAM,kBAAkB,SAAS,MAAM,aAAa,YAAY,SAAS,CAAA,GAAI,QAAQ,CAAC;AACtF,UAAM,eAAe,SAAS,MAAM,gBAAgB,MAAM,UAAU,CAAC,SAAS,KAAK,SAAS,QAAQ,OAAO,IAAI,CAAC;AAChH,UAAM,eAAe,SAAS,MAAM,aAAa,SAAS,IAAI,gBAAgB,MAAM,aAAa,QAAQ,CAAC,KAAK,OAAO,IAAI;AAC1H,UAAM,eAAe,SAAS,MAAM,aAAa,QAAQ,IAAI,gBAAgB,MAAM,aAAa,QAAQ,CAAC,KAAK,OAAO,IAAI;AACzH,UAAM,kBAAkB,SAAS,MAAM,QAAQ,OAAO,aAAa,CAAC,KAAK,IAAI;AAC7E,UAAM,eAAe,SAAS,MAAM;AAClC,YAAM,OAAO,aAAa,OAAO,KAAK,cAAc,QAAQ,QAAQ,EAAE,KAAK;AAC3E,aAAO,QAAQ,SAAS,OAAO,GAAG,IAAI,aAAa,QAAQ,MAAM,IAAI,KAAK;AAAA,IAC5E,CAAC;AAED,UAAM,kBAAkB,SAAS,MAAM;AACrC,UAAI,CAAC,QAAQ,OAAO;AAClB,eAAO,CAAA;AAAA,MACT;AAEA,YAAM,gBAAgB,IAAI,IAAI,QAAQ,MAAM,WAAW,IAAI,CAAC,SAAS,KAAK,IAAI,CAAC;AAC/E,aAAO,gBAAgB,MACpB,OAAO,CAAC,SAAS,KAAK,OAAO,QAAQ,OAAO,MAAM,KAAK,WAAW,KAAK,CAAC,QAAQ,cAAc,IAAI,IAAI,IAAI,CAAC,CAAC,EAC5G,MAAM,GAAG,CAAC;AAAA,IACf,CAAC;AAED,eAAW;AAAA,MACT,OAAO,MAAM,QAAQ,OAAO,SAAS;AAAA,MACrC,aAAa,MAAM,QAAQ,OAAO,WAAW,aAAa,OAAO,mBAAmB;AAAA,IAAA,CACrF;AAED,YAAQ,OAAO;AAAA,MACb,MAAM,aAAa,QACf;AAAA,QACE;AAAA,UACE,KAAK;AAAA,UACL,MAAM,aAAa;AAAA,QAAA;AAAA,MACrB,IAEF,CAAA;AAAA,IAAC,EACL;;;;;;;UAIWC,MAAA,OAAA,GAAO;AAAE,cAAA,OAAAL,eAAAC,WAAA,EAAA,OAAM,WAAO,MAAA,CAAA,CAAA,8OAAA;;UAKb,OAAM;AAAA,UAAuD,IAAG;AAAA,QAAA;2BAA1E,CAA6F,GAAAM,QAAAC,UAAA,aAAA;;;;;gCAAf,MAAI;AAAA,cAAA;AAAA;;;;;;UAExE,OAAM;AAAA,UAA0C,IAAG;AAAA,QAAA;2BAA7D,CAA4F,GAAAD,QAAAC,UAAA,aAAA;;;;;gCAAnB,UAAQ;AAAA,cAAA;AAAA;;;;AAExE,cAAA,uBAAAL,eAAAE,MAAA,eAAA,GAAiB,QAAI,eAAA,CAAA,8DAAA;sBAILA,MAAA,OAAA,EAAQ,MAAI,CAApB,SAAI;;YAAmB,KAAK,KAAK;AAAA,YAAI,OAAM;AAAA,YAAe,IAAE,SAAW,KAAK,IAAI;AAAA,UAAA;6BAAjG,CAAgI,GAAAE,QAAAC,UAAA,aAAA;;AAAvBD,uBAAA,IAAAJ,eAAA,KAAK,IAAI,CAAA,EAAA;AAAA;;kCAAb,MAACM,gBAAG,KAAK,IAAI,GAAA,CAAA;AAAA,gBAAA;AAAA;;;;;kKAIRN,eAAAE,MAAA,OAAA,EAAQ,KAAK,gFAC7CF,eAAAE,MAAA,OAAA,EAAQ,OAAO,2FAGxEF,eAAAE,MAAA,UAAA,EAAW,IAAI,sCACbA,MAAA,OAAA,EAAQ,WAAW,IAAG,CAAE,SAAS,KAAK,IAAI,EAAE,KAAI,KAAA,KAAA,eAAA,uCAC/CA,MAAA,UAAA,EAAWA,MAAA,OAAA,EAAQ,WAAW,CAAA,2BAC3BF,eAAAE,MAAA,OAAA,EAAQ,WAAW;;UAM1B,SAASA,MAAA,OAAA,EAAQ;AAAA,QAAA;;aAOzBA,MAAA,WAAA,GAAW;;;;cAKXA,MAAA,YAAA,GAAY;;cAClB,OAAM;AAAA,cACL,IAAE,aAAeA,MAAA,YAAA,EAAa,IAAI;AAAA,YAAA;+BAHrC,CAMW,GAAAE,QAAAC,UAAA,aAAA;;AADND,yBAAA,GAAAJ,eAAAE,MAAA,YAAA,EAAa,KAAK,CAAA,EAAA;AAAA;;oBAAlBK,gBAAAD,gBAAAJ,MAAA,YAAA,EAAa,KAAK,GAAA,CAAA;AAAA,kBAAA;AAAA;;;;;;cAEN,OAAM;AAAA,cAAiE,IAAG;AAAA,YAAA;+BAA3F,CAAqI,GAAAE,QAAAC,UAAA,aAAA;;;;;oCAA9B,qBAAmB;AAAA,kBAAA;AAAA;;;;;;cAMlHH,MAAA,YAAA,GAAY;;cAClB,OAAM;AAAA,cACL,IAAE,aAAeA,MAAA,YAAA,EAAa,IAAI;AAAA,YAAA;+BAHrC,CAMW,GAAAE,QAAAC,UAAA,aAAA;;AADND,yBAAA,GAAAJ,eAAAE,MAAA,YAAA,EAAa,KAAK,CAAA,EAAA;AAAA;;oBAAlBK,gBAAAD,gBAAAJ,MAAA,YAAA,EAAa,KAAK,GAAA,CAAA;AAAA,kBAAA;AAAA;;;;;;cAEN,OAAM;AAAA,cAA+E,IAAG;AAAA,YAAA;+BAAzG,CAAgJ,GAAAE,QAAAC,UAAA,aAAA;;;;;oCAA3B,kBAAgB;AAAA,kBAAA;AAAA;;;;;;;;;UAK1H,gBAAcH,MAAA,OAAA,EAAQ;AAAA,UAAO,iBAAeA,MAAA,OAAA,EAAQ;AAAA,QAAA;;AAGxD,YAAAA,MAAA,eAAA,EAAgB,SAAM,GAAA;;;YAOrB,OAAM;AAAA,YAAiD,IAAIA,MAAA,eAAA,IAAe,eAAkBA,MAAA,eAAA,EAAgB,IAAI,KAAA;AAAA,UAAA;6BAA1H,CAEW,GAAAE,QAAAC,UAAA,aAAA;;;;;kCAFiI,yBAE5I;AAAA,gBAAA;AAAA;;;;;AAI4BN,wBAAAG,MAAA,eAAA,IAAR,SAAI;;cAAsB,KAAK,KAAK;AAAA,cAAK,SAAS;AAAA,cAAM,SAAQ;AAAA,YAAA;;;;;;;;AAM5E,cAAA,WAAAL,eAAAC,WAAA,EAAA,OAAM,kCAA8B,MAAA,CAAA,CAAA,GAAA;;UAEhD,OAAM;AAAA,UACN,aAAY;AAAA,UACZ,gBAAa;AAAA,UACb,eAAY;AAAA,QAAA;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderList","_ssrInterpolate","_withAsyncContext","_unref","_ssrRenderComponent","_push","_parent","_toDisplayString","_createTextVNode"],"sources":["../../../../components/CommentThread.vue","../../../../components/CommentSection.vue","../../../../pages/articles/[slug].vue"],"sourcesContent":["<script setup lang=\"ts\">\nimport AppImage from '~/components/AppImage.vue';\nimport type { BlogComment } from '~/types/blog';\n\ndefineProps<{\n  comments: BlogComment[];\n}>();\n</script>\n\n<template>\n  <div class=\"space-y-6\">\n    <div v-for=\"comment in comments\" :key=\"comment.id\" class=\"border-l border-[var(--blog-border)] pl-5\">\n      <div class=\"flex gap-4\">\n        <AppImage class=\"h-10 w-10 rounded-full object-cover\" :src=\"comment.avatarUrl\" :alt=\"comment.nickname\" />\n        <div class=\"min-w-0 flex-1\">\n          <div class=\"flex flex-wrap items-center gap-2\">\n            <span class=\"text-sm font-semibold text-[var(--blog-ink)]\">{{ comment.nickname }}</span>\n            <span class=\"text-xs text-[var(--blog-subtle)]\">{{ new Date(comment.createdAt).toLocaleDateString('zh-CN') }}</span>\n          </div>\n          <p class=\"mt-3 text-sm leading-7 text-[var(--blog-muted)]\">{{ comment.content }}</p>\n        </div>\n      </div>\n\n      <div v-if=\"comment.replies.length > 0\" class=\"mt-4 space-y-4\">\n        <CommentThread :comments=\"comment.replies\" />\n      </div>\n    </div>\n  </div>\n</template>\n","<script setup lang=\"ts\">\nimport { fetchCaptchaConfig, fetchPublicComments, submitPublicComment } from '~/composables/api';\nimport { useGeeTestCaptcha } from '~/composables/useGeeTestCaptcha';\nimport type { AdminCaptchaResult } from '~/types/admin';\n\nconst props = defineProps<{\n  articleSlug: string;\n  allowComment: boolean;\n}>();\n\nconst nickname = ref('');\nconst email = ref('');\nconst website = ref('');\nconst content = ref('');\nconst message = ref('');\nconst submitting = ref(false);\nconst captchaEnabled = ref(false);\nconst captchaId = ref<string | null>(null);\n\nconst { data: comments, refresh, pending } = await useAsyncData(\n  () => `comments-${props.articleSlug}`,\n  () => fetchPublicComments(props.articleSlug),\n);\n\nconst { loaded: captchaLoaded, showCaptcha } = useGeeTestCaptcha(\n  captchaId,\n  async (result) => {\n    await performSubmit(result);\n  },\n  (error) => {\n    message.value = error.message;\n  },\n);\n\nasync function performSubmit(captcha?: AdminCaptchaResult) {\n  if (!props.allowComment || !nickname.value.trim() || !email.value.trim() || !content.value.trim()) {\n    return;\n  }\n\n  submitting.value = true;\n  message.value = '';\n\n  try {\n    await submitPublicComment(props.articleSlug, {\n      nickname: nickname.value.trim(),\n      email: email.value.trim(),\n      website: website.value.trim() || undefined,\n      content: content.value.trim(),\n      captcha,\n    });\n\n    nickname.value = '';\n    email.value = '';\n    website.value = '';\n    content.value = '';\n    message.value = 'Comment received. It will appear after moderation.';\n    await refresh();\n  } catch (error) {\n    message.value = error instanceof Error ? error.message : 'Comment submission failed.';\n  } finally {\n    submitting.value = false;\n  }\n}\n\nasync function handleSubmit() {\n  if (captchaEnabled.value) {\n    if (!captchaLoaded.value) {\n      message.value = 'Captcha is still loading. Please try again in a moment.';\n      return;\n    }\n\n    showCaptcha();\n    return;\n  }\n\n  await performSubmit();\n}\n\nonMounted(async () => {\n  try {\n    const config = await fetchCaptchaConfig();\n\n    if (config.enabled && config.enabledOnComment && config.captchaId?.trim()) {\n      captchaEnabled.value = true;\n      captchaId.value = config.captchaId.trim();\n    }\n  } catch {\n    // Keep comment submission available if captcha config bootstrap fails.\n  }\n});\n</script>\n\n<template>\n  <section class=\"mt-16\">\n    <div class=\"flex items-center gap-3\">\n      <h2 class=\"text-2xl font-semibold text-[var(--blog-ink)]\">Comments</h2>\n      <span class=\"rounded-full bg-[var(--blog-soft)] px-3 py-1 text-xs text-[var(--blog-subtle)]\">{{ comments?.length || 0 }}</span>\n    </div>\n\n    <div v-if=\"allowComment\" class=\"blog-panel mt-8 rounded-none p-6 sm:rounded-[4px] md:p-8\">\n      <h3 class=\"text-lg font-semibold text-[var(--blog-ink)]\">Share your thoughts</h3>\n      <form class=\"mt-5 space-y-4\" @submit.prevent=\"handleSubmit\">\n        <div class=\"grid gap-4 md:grid-cols-2\">\n          <input v-model=\"nickname\" class=\"w-full rounded-2xl border border-[var(--blog-border)] bg-[var(--blog-soft)] px-4 py-3 text-sm outline-none\" placeholder=\"Name\" required>\n          <input v-model=\"email\" class=\"w-full rounded-2xl border border-[var(--blog-border)] bg-[var(--blog-soft)] px-4 py-3 text-sm outline-none\" placeholder=\"Email\" type=\"email\" required>\n        </div>\n        <input v-model=\"website\" class=\"w-full rounded-2xl border border-[var(--blog-border)] bg-[var(--blog-soft)] px-4 py-3 text-sm outline-none\" placeholder=\"Website (optional)\" type=\"url\">\n        <textarea\n          v-model=\"content\"\n          class=\"min-h-32 w-full rounded-3xl border border-[var(--blog-border)] bg-[var(--blog-soft)] px-4 py-3 text-sm leading-7 outline-none\"\n          placeholder=\"Write a comment...\"\n          required\n        ></textarea>\n\n        <p v-if=\"captchaEnabled\" class=\"text-xs text-[var(--blog-muted)]\">\n          GeeTest verification is required before this comment can be submitted.\n        </p>\n\n        <div class=\"flex flex-wrap items-center gap-3\">\n          <button class=\"blog-button-primary\" type=\"submit\" :disabled=\"submitting\">\n            {{ submitting ? 'Submitting...' : 'Post comment' }}\n          </button>\n          <span v-if=\"message\" class=\"text-sm text-[var(--blog-muted)]\">{{ message }}</span>\n        </div>\n      </form>\n    </div>\n\n    <div v-else class=\"blog-panel mt-8 rounded-none p-8 text-center text-sm text-[var(--blog-subtle)] sm:rounded-[4px]\">\n      Comments are disabled for this article.\n    </div>\n\n    <div v-if=\"pending\" class=\"blog-panel mt-8 rounded-none p-8 text-center text-sm text-[var(--blog-subtle)] sm:rounded-[4px]\">\n      Loading comments...\n    </div>\n    <div v-else-if=\"comments && comments.length > 0\" class=\"mt-8 rounded-none border border-[var(--blog-border)] bg-white/88 px-4 py-6 sm:rounded-[4px] sm:px-6\">\n      <CommentThread :comments=\"comments\" />\n    </div>\n    <div v-else class=\"blog-panel mt-8 rounded-none p-8 text-center text-sm text-[var(--blog-subtle)] sm:rounded-[4px]\">\n      No comments yet. Be the first to leave one.\n    </div>\n  </section>\n</template>\n","<script setup lang=\"ts\">\nimport {\n  blogAuthor,\n  fetchAllPublicArticles,\n  fetchPublicArticleDetail,\n  fetchPublicSiteSettings,\n  formatDate,\n  sortArticles,\n} from '~/composables/api';\n\nconst route = useRoute();\nconst slug = computed(() => String(route.params.slug || ''));\nconst { data: siteSettings } = await useAsyncData('site-settings', fetchPublicSiteSettings);\n\n// 核心数据阻塞加载（文章详情）\nconst { data: article } = await useAsyncData(() => `article-${slug.value}`, () => fetchPublicArticleDetail(slug.value));\n\n// 上下篇和推荐文章数据非阻塞加载（lazy: true）\nconst { data: allArticles } = useAsyncData('shared-all-articles', fetchAllPublicArticles, { lazy: true });\n\nconst orderedArticles = computed(() => sortArticles(allArticles.value || [], 'latest'));\nconst articleIndex = computed(() => orderedArticles.value.findIndex((item) => item.slug === article.value?.slug));\nconst olderArticle = computed(() => articleIndex.value >= 0 ? orderedArticles.value[articleIndex.value + 1] || null : null);\nconst newerArticle = computed(() => articleIndex.value > 0 ? orderedArticles.value[articleIndex.value - 1] || null : null);\nconst primaryCategory = computed(() => article.value?.categories?.[0] || null);\nconst canonicalUrl = computed(() => {\n  const base = siteSettings.value?.seo?.canonicalUrl?.replace(/\\/+$/, '') || '';\n  return article.value && base ? `${base}/articles/${article.value.slug}` : '';\n});\n\nconst relatedArticles = computed(() => {\n  if (!article.value) {\n    return [];\n  }\n\n  const categorySlugs = new Set(article.value.categories.map((item) => item.slug));\n  return orderedArticles.value\n    .filter((item) => item.id !== article.value?.id && item.categories.some((cat) => categorySlugs.has(cat.slug)))\n    .slice(0, 3);\n});\n\nuseSeoMeta({\n  title: () => article.value?.title || 'Article',\n  description: () => article.value?.excerpt || siteSettings.value?.siteDescription || '',\n});\n\nuseHead(() => ({\n  link: canonicalUrl.value\n    ? [\n        {\n          rel: 'canonical',\n          href: canonicalUrl.value,\n        },\n      ]\n    : [],\n}));\n</script>\n\n<template>\n  <div v-if=\"article\" class=\"pb-20\">\n    <section class=\"mx-auto max-w-7xl px-0 pt-4 sm:px-6\">\n      <div class=\"blog-panel overflow-hidden rounded-none sm:rounded-[4px]\">\n        <div class=\"p-6 md:p-8 lg:p-10\">\n          <div class=\"flex flex-wrap items-center gap-2 text-sm text-[var(--blog-muted)]\">\n            <NuxtLink class=\"text-[var(--blog-accent)] transition hover:underline\" to=\"/\">Home</NuxtLink>\n            <span>/</span>\n            <NuxtLink class=\"transition hover:text-[var(--blog-ink)]\" to=\"/articles\">Articles</NuxtLink>\n            <span>/</span>\n            <span>{{ primaryCategory?.name || 'Uncategorized' }}</span>\n          </div>\n\n          <div class=\"mt-6 flex flex-wrap gap-2\">\n            <NuxtLink v-for=\"item in article.tags\" :key=\"item.id\" class=\"blog-filter\" :to=\"`/tags/${item.slug}`\">#{{ item.name }}</NuxtLink>\n          </div>\n\n          <div class=\"mt-8 max-w-4xl\">\n            <h1 class=\"text-2xl font-semibold leading-tight tracking-[-0.03em] text-[var(--blog-ink)] md:text-4xl\">{{ article.title }}</h1>\n            <p class=\"mt-4 max-w-3xl text-base leading-8 text-[var(--blog-muted)]\">{{ article.excerpt }}</p>\n\n            <ul class=\"mt-8 flex flex-wrap gap-4 text-sm text-[var(--blog-muted)]\">\n              <li>Author: {{ blogAuthor.name }}</li>\n              <li>Category: {{ article.categories.map((item) => item.name).join(' / ') || 'Uncategorized' }}</li>\n              <li>Published: {{ formatDate(article.publishedAt) }}</li>\n              <li>Reading time: {{ article.readingTime }} min</li>\n            </ul>\n          </div>\n        </div>\n\n        <div class=\"border-t border-[var(--blog-border)]\">\n          <MarkdownContent :content=\"article.content\" />\n        </div>\n      </div>\n    </section>\n\n    <section class=\"mx-auto max-w-7xl px-0 pt-0 sm:px-6\">\n      <div class=\"mt-8 blog-panel rounded-none px-6 py-6 sm:rounded-[4px] md:px-10 md:py-8\">\n        <div v-if=\"!allArticles\" class=\"text-center text-sm text-[var(--blog-subtle)]\">Loading navigation...</div>\n        <div v-else class=\"flex flex-col gap-5 md:flex-row md:justify-between md:gap-6\">\n          <div class=\"flex w-full flex-col text-[var(--blog-muted)] md:w-1/2\">\n            <span class=\"text-xs uppercase tracking-[0.18em] text-[var(--blog-subtle)]\">Older post</span>\n            <NuxtLink\n              v-if=\"olderArticle\"\n              class=\"mt-2 inline-flex items-center gap-2 text-base font-medium leading-7 text-[var(--blog-ink)] transition hover:text-[var(--blog-accent)]\"\n              :to=\"`/articles/${olderArticle.slug}`\"\n            >\n              {{ olderArticle.title }}\n            </NuxtLink>\n            <NuxtLink v-else class=\"mt-2 text-base font-medium leading-7 text-[var(--blog-subtle)]\" to=\"/articles\">Browse all articles</NuxtLink>\n          </div>\n\n          <div class=\"flex w-full flex-col text-left text-[var(--blog-muted)] md:w-1/2 md:items-end\">\n            <span class=\"text-xs uppercase tracking-[0.18em] text-[var(--blog-subtle)]\">Newer post</span>\n            <NuxtLink\n              v-if=\"newerArticle\"\n              class=\"mt-2 inline-flex items-center gap-2 text-base font-medium leading-7 text-[var(--blog-ink)] transition hover:text-[var(--blog-accent)] md:text-right\"\n              :to=\"`/articles/${newerArticle.slug}`\"\n            >\n              {{ newerArticle.title }}\n            </NuxtLink>\n            <NuxtLink v-else class=\"mt-2 text-base font-medium leading-7 text-[var(--blog-subtle)] md:text-right\" to=\"/articles\">No newer article</NuxtLink>\n          </div>\n        </div>\n      </div>\n\n      <CommentSection :article-slug=\"article.slug\" :allow-comment=\"article.allowComment\" />\n    </section>\n\n    <section v-if=\"relatedArticles.length > 0\" class=\"mt-16 border-t border-[var(--blog-border)] bg-white/70 py-16\">\n      <div class=\"mx-auto max-w-7xl px-0 sm:px-6\">\n        <div class=\"flex flex-col gap-4 md:flex-row md:items-end md:justify-between\">\n          <div>\n            <p class=\"text-xs font-semibold uppercase tracking-[0.22em] text-[var(--blog-subtle)]\">Related</p>\n            <h2 class=\"mt-3 text-3xl font-semibold tracking-[-0.03em] text-[var(--blog-ink)]\">Related reads</h2>\n          </div>\n          <NuxtLink class=\"text-sm font-medium text-[var(--blog-accent)]\" :to=\"primaryCategory ? `/categories/${primaryCategory.slug}` : '/articles'\">\n            More in this category\n          </NuxtLink>\n        </div>\n\n        <div class=\"mt-8 grid gap-4 md:grid-cols-3\">\n          <ArticleCard v-for=\"item in relatedArticles\" :key=\"item.id\" :article=\"item\" variant=\"compact\" />\n        </div>\n      </div>\n    </section>\n  </div>\n\n  <section v-else class=\"mx-auto max-w-4xl px-6 py-16\">\n    <EmptyState\n      title=\"Article not found\"\n      description=\"The requested article is unavailable or has been removed.\"\n      action-label=\"Back to articles\"\n      action-href=\"/articles\"\n    />\n  </section>\n</template>\n"],"version":3}