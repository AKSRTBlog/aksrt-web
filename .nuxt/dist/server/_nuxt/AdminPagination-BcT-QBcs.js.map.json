{"file":"AdminPagination-BcT-QBcs.js","mappings":";;;;;;;;;;;;;;mBA2BOA,eAAAC,WAAA,EAAA,OAAM,mBAAA,GAAkB,MAAA,CAAA,yDAEpB,QAAA,KAAK,oBAAO,QAAA,KAAK,sBAAS,QAAA,IAAI,sBAAS,QAAA,UAAU,0HAGU,QAAA,QAAI,CAAA,IAAA,cAAA,wEAGJC,sBAAA,QAAA,QAAQ,QAAA,UAAU,IAAA,cAAA;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrIncludeBooleanAttr"],"sources":["../../../../components/admin/AdminPagination.vue"],"sourcesContent":["<script setup lang=\"ts\">\nconst props = withDefaults(\n  defineProps<{\n    page: number\n    totalPages: number\n    total: number\n    label?: string\n  }>(),\n  {\n    label: '条数据',\n  },\n)\n\nconst emit = defineEmits<{\n  'update:page': [page: number]\n}>()\n\nfunction goToPrevious() {\n  emit('update:page', Math.max(1, props.page - 1))\n}\n\nfunction goToNext() {\n  emit('update:page', Math.min(props.totalPages, props.page + 1))\n}\n</script>\n\n<template>\n  <div class=\"admin-pagination\">\n    <p class=\"text-sm text-slate-500\">\n      共 {{ total }} {{ label }}，第 {{ page }} / {{ totalPages }} 页\n    </p>\n    <div class=\"flex items-center gap-2\">\n      <button class=\"admin-button-secondary\" type=\"button\" :disabled=\"page <= 1\" @click=\"goToPrevious\">\n        上一页\n      </button>\n      <button class=\"admin-button-secondary\" type=\"button\" :disabled=\"page >= totalPages\" @click=\"goToNext\">\n        下一页\n      </button>\n    </div>\n  </div>\n</template>\n"],"version":3}