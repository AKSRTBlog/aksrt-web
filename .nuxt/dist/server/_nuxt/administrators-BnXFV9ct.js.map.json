{"file":"administrators-BnXFV9ct.js","mappings":";;;;;;;;;;;;;;;;;;;;AAMA,YAAQ;AAAA,MACN,OAAO;AAAA,IAAA,CACR;AAEiD,oBAAA;AACnC,cAAA;AAEf,UAAM,UAAU,IAAI,IAAI;AACxB,UAAM,SAAS,IAAI,KAAK;AACxB,UAAM,mBAAmB,IAAI,KAAK;AAClC,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,iBAAiB,IAAI,EAAE;AAE7B,UAAM,cAAc,IAAI;AAAA,MACtB,UAAU;AAAA,MACV,OAAO;AAAA,MACP,aAAa;AAAA,IAAA,CACd;AAED,UAAM,eAAe,IAAI;AAAA,MACvB,iBAAiB;AAAA,MACjB,aAAa;AAAA,MACb,iBAAiB;AAAA,IAAA,CAClB;;;AAgGM,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,eAAW,MAAA,CAAA,CAAA,GAAA;;QAElB,OAAM;AAAA,QACN,aAAY;AAAA,MAAA;UAGHC,MAAA,KAAA,GAAK;6HACXA,MAAA,KAAA,CAAK,CAAA,QAAA;AAAA;;;UAECA,MAAA,cAAA,GAAc;sIACpBA,MAAA,cAAA,CAAc,CAAA,QAAA;AAAA;;;UAGRA,MAAA,OAAA,GAAO;;;ivBAwBKC,cAAA,SAAAD,MAAA,WAAA,EAAY,QAAQ,+MAWpBC,cAAA,SAAAD,MAAA,WAAA,EAAY,KAAK,oNAWjBC,cAAA,SAAAD,MAAA,WAAA,EAAY,WAAW,kOAYvBA,MAAA,MAAA,CAAM,IAAA,cAAA,oRAMdA,MAAA,MAAA,IAAM,WAAA,MAAA,oxBAwBEC,cAAA,SAAAD,MAAA,YAAA,EAAa,eAAe,8JAU5BC,cAAA,SAAAD,MAAA,YAAA,EAAa,WAAW,uKAUxBC,cAAA,SAAAD,MAAA,YAAA,EAAa,eAAe,6JAW5BE,sBAAAF,MAAA,gBAAA,MAAqBA,MAAA,YAAA,EAAa,mBAAe,CAAKA,MAAA,YAAA,EAAa,WAAW,IAAA,cAAA,mTAMtFA,MAAA,gBAAA,IAAgB,WAAA,MAAA;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_ssrRenderAttr","_ssrIncludeBooleanAttr"],"sources":["../../../../pages/admin/administrators.vue"],"sourcesContent":["<script setup lang=\"ts\">\ndefinePageMeta({\n  layout: 'admin',\n  middleware: 'admin-auth',\n})\n\nuseHead({\n  title: '管理员设置',\n})\n\nconst { adminApiFetch, refreshProfile, logout } = useAdminSession()\nconst router = useRouter()\n\nconst loading = ref(true)\nconst saving = ref(false)\nconst changingPassword = ref(false)\nconst error = ref('')\nconst successMessage = ref('')\n\nconst profileForm = ref({\n  username: '',\n  email: '',\n  displayName: '',\n})\n\nconst passwordForm = ref({\n  currentPassword: '',\n  newPassword: '',\n  confirmPassword: '',\n})\n\nasync function loadProfile() {\n  loading.value = true\n  error.value = ''\n\n  try {\n    const result = await adminApiFetch<{\n      username: string\n      email: string\n      displayName: string\n    }>('/api/v1/admin/auth/me')\n\n    profileForm.value = {\n      username: result.username,\n      email: result.email,\n      displayName: result.displayName,\n    }\n  } catch (e) {\n    error.value = e instanceof Error ? e.message : '加载失败'\n  } finally {\n    loading.value = false\n  }\n}\n\nasync function saveProfile() {\n  saving.value = true\n  error.value = ''\n  successMessage.value = ''\n\n  try {\n    await adminApiFetch('/api/v1/admin/auth/me', {\n      method: 'PATCH',\n      body: JSON.stringify(profileForm.value),\n    })\n\n    await refreshProfile()\n    successMessage.value = '保存成功'\n    window.setTimeout(() => {\n      successMessage.value = ''\n    }, 3000)\n  } catch (e) {\n    error.value = e instanceof Error ? e.message : '保存失败'\n  } finally {\n    saving.value = false\n  }\n}\n\nasync function changePassword() {\n  if (passwordForm.value.newPassword !== passwordForm.value.confirmPassword) {\n    error.value = '两次输入的新密码不一致'\n    return\n  }\n\n  if (passwordForm.value.newPassword.length < 8) {\n    error.value = '新密码长度至少为 8 位'\n    return\n  }\n\n  changingPassword.value = true\n  error.value = ''\n  successMessage.value = ''\n\n  try {\n    await adminApiFetch('/api/v1/admin/auth/change-password', {\n      method: 'POST',\n      body: JSON.stringify({\n        currentPassword: passwordForm.value.currentPassword,\n        newPassword: passwordForm.value.newPassword,\n      }),\n    })\n\n    successMessage.value = '密码修改成功，3 秒后将自动退出登录...'\n    passwordForm.value = {\n      currentPassword: '',\n      newPassword: '',\n      confirmPassword: '',\n    }\n\n    window.setTimeout(() => {\n      logout()\n      void router.push('/admin/login')\n    }, 3000)\n  } catch (e) {\n    error.value = e instanceof Error ? e.message : '密码修改失败'\n  } finally {\n    changingPassword.value = false\n  }\n}\n\nonMounted(() => {\n  void loadProfile()\n})\n</script>\n\n<template>\n  <div class=\"space-y-6\">\n    <AdminPageHeader\n      title=\"管理员设置\"\n      description=\"管理登录账户信息和安全设置。\"\n    />\n\n    <div v-if=\"error\" class=\"rounded-[4px] border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700\">\n      {{ error }}\n    </div>\n    <div v-if=\"successMessage\" class=\"rounded-[4px] border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700\">\n      {{ successMessage }}\n    </div>\n\n    <div v-if=\"loading\" class=\"admin-card p-6 text-center text-sm text-slate-500\">\n      正在加载...\n    </div>\n\n    <template v-else>\n      <div class=\"grid gap-6 xl:grid-cols-2\">\n        <section class=\"admin-card flex h-full flex-col p-6\">\n          <div class=\"mb-6 flex items-center gap-4\">\n            <div class=\"flex h-16 w-16 items-center justify-center rounded-full bg-blue-100\">\n              <svg class=\"h-8 w-8 text-blue-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z\" />\n              </svg>\n            </div>\n            <div>\n              <h3 class=\"text-lg font-semibold text-slate-900\">账户信息</h3>\n              <p class=\"text-sm text-slate-500\">修改您的登录邮箱、用户名和显示名称。</p>\n            </div>\n          </div>\n\n          <div class=\"flex flex-1 flex-col\">\n            <div class=\"space-y-6\">\n              <div>\n                <label class=\"mb-2 block text-sm font-medium text-slate-700\">用户名</label>\n                <input\n                  v-model=\"profileForm.username\"\n                  type=\"text\"\n                  class=\"admin-input w-full\"\n                  placeholder=\"输入用户名\"\n                >\n                <p class=\"mt-1 text-xs text-slate-500\">用于登录后台管理系统</p>\n              </div>\n\n              <div>\n                <label class=\"mb-2 block text-sm font-medium text-slate-700\">邮箱地址</label>\n                <input\n                  v-model=\"profileForm.email\"\n                  type=\"email\"\n                  class=\"admin-input w-full\"\n                  placeholder=\"输入邮箱地址\"\n                >\n                <p class=\"mt-1 text-xs text-slate-500\">用于接收系统通知和密码重置</p>\n              </div>\n\n              <div>\n                <label class=\"mb-2 block text-sm font-medium text-slate-700\">显示名称</label>\n                <input\n                  v-model=\"profileForm.displayName\"\n                  type=\"text\"\n                  class=\"admin-input w-full\"\n                  placeholder=\"输入显示名称\"\n                >\n                <p class=\"mt-1 text-xs text-slate-500\">显示在后台界面中的名称</p>\n              </div>\n            </div>\n\n            <div class=\"mt-auto flex gap-3 pt-6\">\n              <button\n                class=\"admin-button-primary\"\n                :disabled=\"saving\"\n                @click=\"saveProfile\"\n              >\n                <svg class=\"h-4 w-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4\" />\n                </svg>\n                {{ saving ? '保存中...' : '保存修改' }}\n              </button>\n            </div>\n          </div>\n        </section>\n\n        <section class=\"admin-card flex h-full flex-col p-6\">\n          <div class=\"mb-6 flex items-center gap-4\">\n            <div class=\"flex h-16 w-16 items-center justify-center rounded-full bg-amber-100\">\n              <svg class=\"h-8 w-8 text-amber-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z\" />\n              </svg>\n            </div>\n            <div>\n              <h3 class=\"text-lg font-semibold text-slate-900\">修改密码</h3>\n              <p class=\"text-sm text-slate-500\">定期更新密码可以提升账户安全性。</p>\n            </div>\n          </div>\n\n          <div class=\"flex flex-1 flex-col\">\n            <div class=\"space-y-6\">\n              <div>\n                <label class=\"mb-2 block text-sm font-medium text-slate-700\">当前密码</label>\n                <input\n                  v-model=\"passwordForm.currentPassword\"\n                  type=\"password\"\n                  class=\"admin-input w-full\"\n                  placeholder=\"输入当前密码\"\n                >\n              </div>\n\n              <div>\n                <label class=\"mb-2 block text-sm font-medium text-slate-700\">新密码</label>\n                <input\n                  v-model=\"passwordForm.newPassword\"\n                  type=\"password\"\n                  class=\"admin-input w-full\"\n                  placeholder=\"输入新密码（至少 8 位）\"\n                >\n              </div>\n\n              <div>\n                <label class=\"mb-2 block text-sm font-medium text-slate-700\">确认新密码</label>\n                <input\n                  v-model=\"passwordForm.confirmPassword\"\n                  type=\"password\"\n                  class=\"admin-input w-full\"\n                  placeholder=\"再次输入新密码\"\n                >\n              </div>\n            </div>\n\n            <div class=\"mt-auto flex gap-3 pt-6\">\n              <button\n                class=\"admin-button-secondary\"\n                :disabled=\"changingPassword || !passwordForm.currentPassword || !passwordForm.newPassword\"\n                @click=\"changePassword\"\n              >\n                <svg class=\"h-4 w-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z\" />\n                </svg>\n                {{ changingPassword ? '修改中...' : '修改密码' }}\n              </button>\n            </div>\n          </div>\n        </section>\n      </div>\n    </template>\n  </div>\n</template>\n"],"version":3}