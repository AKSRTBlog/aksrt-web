AM,KAAA,kBAANA,MAAA,MAAA,GAAM,KAAA,CAAA,IAAA,cAAA,gFAANA,MAAA,MAAA,CAAM,oBAANA,MAAA,MAAA,GAAM,WAAA,kBAANA,MAAA,MAAA,GAAM,WAAA,CAAA,IAAA,cAAA,2EAANA,MAAA,MAAA,CAAM,oBAANA,MAAA,MAAA,GAAM,OAAA,kBAANA,MAAA,MAAA,GAAM,OAAA,CAAA,IAAA,cAAA,8HAMNA,MAAA,UAAA,CAAU,oBAAVA,MAAA,UAAA,GAAU,KAAA,kBAAVA,MAAA,UAAA,GAAU,KAAA,CAAA,IAAA,cAAA;oBAEFA,MAAA,OAAA,EAAQ,YAAU,CAA1B,SAAI;sCAAwC,SAAO,KAAK,EAAE,wCAF1DA,MAAA,UAAA,CAAU,oBAAVA,MAAA,UAAA,GAEmD,KAAK,EAAE,kBAF1DA,MAAA,UAAA,GAEmD,KAAK,EAAE,CAAA,IAAA,cAAA,MACpEK,eAAA,KAAK,IAAI;;;UAQdL,MAAA,YAAA,GAAY;0HAGfA,MAAA,YAAA,CAAY,CAAA,QAAA;AAAA;;;;AASWM,oBAAA,CAAA,MAAA,MAAA,MAAA,QAAA,QAAA,IAAA,IAAT,UAAK;uHAIT,KAAK,CAAA,OAAA;AAAA;;UAKFN,MAAA,OAAA,GAAO;;MAMF,WAAAA,MAAA,KAAA,EAAM,WAAM,GAAA;;;;AAQLM,sBAAAN,MAAA,KAAA,IAAX,YAAO;;AAOF,cAAA,QAAQ,eAAa;oFAE1B,OAAK,QAAQ,aAAa,kBAC1B,OAAK,QAAQ,KAAK;;;;iGAUyCK,eAAA,QAAQ,KAAK,sEACRA,eAAA,QAAQ,OAAO,sEAOlFA,eAAA,QAAQ,cAAc,QAAQ,WAAW,SAAM,IAA6B,QAAQ,WAAW,IAAG,CAAE,QAAQ,IAAI,IAAI,EAAE,KAAI,IAAA;;YAOzG,MAAM,QAAQ,WAAM,cAAA,YAAA;AAAA,UAAA;6BAAvC,CAEmB,GAAAP,QAAAC,UAAA,aAAA;;AADdD,uBAAA,GAAAO,eAAA,QAAQ,WAAM,cAAA,QAAA,IAAA,CAAA,EAAA;AAAA;;kBAAdE,gBAAAC,gBAAA,QAAQ,WAAM,cAAA,QAAA,IAAA,GAAA,CAAA;AAAA,gBAAA;AAAA;;;;qEAKhBH,eAAA,QAAQ,cAAcL,uBAAgB,QAAQ,WAAW,IAAA,KAAA,qEAGdA,MAAA,eAAA,EAAgB,QAAQ,SAAS,CAAA;;YAK3E,OAAM;AAAA,YACL,IAAE,aAAe,QAAQ,IAAI;AAAA,YAC9B,QAAO;AAAA,UAAA;6BAHT,CAMW,GAAAF,QAAAC,UAAA,aAAA;;;;;kCAFV,MAED;AAAA,gBAAA;AAAA;;;;;YACU,OAAM;AAAA,YAA0B,IAAIC,MAAA,UAAA,EAAW,YAAY,QAAQ,EAAE;AAAA,UAAA;6BAA/E,CAEW,GAAAF,QAAAC,UAAA,aAAA;;;;;kCAFuE,MAElF;AAAA,gBAAA;AAAA;;;;0FAIaC,MAAA,MAAA,MAAW,QAAQ,EAAE,IAAA,cAAA,qBAG7BA,MAAA,MAAA,MAAW,QAAQ,KAAE,WAAA,IAAA;;;;;;QAWrC,MAAM,KAAK,IAAIA,MAAA,IAAA,GAAMA,MAAA,UAAA,CAAU;AAAA,QAC/B,OAAOA,MAAA,KAAA;AAAA,QACP,eAAaA,MAAA,UAAA;AAAA,QACd,OAAM;AAAA,QACL,iBAAW,CAAA,WAAE,KAAA,QAAO;AAAA,MAAA;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_unref","_","_scopeId","_createVNode","_isRef","_ssrInterpolate","_ssrRenderList","_createTextVNode","_toDisplayString"],"sources":["../../../../pages/admin/articles/index.vue"],"sourcesContent":["<script setup lang=\"ts\">\nimport type { ArticleEditorOptions, ArticleSummaryItem, PaginatedResponse } from '~/types/admin';\nimport { AdminApiError, useAdminSession } from '~/composables/useAdminSession';\nimport { adminPaths, formatAdminDate } from '~/utils/admin';\n\ndefinePageMeta({\n  layout: 'admin',\n  middleware: 'admin-auth',\n});\n\nuseHead({\n  title: 'Admin Articles',\n});\n\nconst PAGE_SIZE = 6;\n\nconst { adminApiFetch, logout, hydrateSession } = useAdminSession();\n\nconst items = ref<ArticleSummaryItem[]>([]);\nconst options = ref<ArticleEditorOptions>({ categories: [], tags: [] });\nconst keyword = ref('');\nconst status = ref<'all' | 'published' | 'draft'>('all');\nconst categoryId = ref('all');\nconst page = ref(1);\nconst total = ref(0);\nconst loading = ref(true);\nconst errorMessage = ref('');\nconst busyId = ref<string | null>(null);\n\nconst totalPages = computed(() => Math.max(1, Math.ceil(total.value / PAGE_SIZE)));\n\nfunction buildArticleListPath() {\n  const params = new URLSearchParams({\n    page: String(page.value),\n    pageSize: String(PAGE_SIZE),\n    sortBy: 'updatedAt',\n    sortOrder: 'desc',\n  });\n\n  if (keyword.value.trim()) {\n    params.set('keyword', keyword.value.trim());\n  }\n\n  if (status.value !== 'all') {\n    params.set('status', status.value);\n  }\n\n  if (categoryId.value !== 'all') {\n    params.set('categoryId', categoryId.value);\n  }\n\n  return `/api/v1/admin/articles?${params.toString()}`;\n}\n\nasync function loadArticles() {\n  loading.value = true;\n  errorMessage.value = '';\n  hydrateSession();\n\n  try {\n    const [articleResult, optionResult] = await Promise.all([\n      adminApiFetch<PaginatedResponse<ArticleSummaryItem>>(buildArticleListPath()),\n      adminApiFetch<ArticleEditorOptions>('/api/v1/admin/articles/meta/options'),\n    ]);\n\n    items.value = articleResult.list;\n    total.value = articleResult.total;\n    options.value = optionResult;\n  } catch (error) {\n    if (error instanceof AdminApiError && error.status === 401) {\n      logout();\n      await navigateTo(adminPaths.login);\n      return;\n    }\n\n    errorMessage.value = error instanceof Error ? error.message : '文章列表加载失败，请稍后重试。';\n  } finally {\n    loading.value = false;\n  }\n}\n\nasync function handleDelete(article: ArticleSummaryItem) {\n  if (!window.confirm(`确定删除文章《${article.title}》吗？`)) {\n    return;\n  }\n\n  busyId.value = article.id;\n  errorMessage.value = '';\n\n  try {\n    await adminApiFetch(`/api/v1/admin/articles/${article.id}`, {\n      method: 'DELETE',\n    });\n\n    if (items.value.length === 1 && page.value > 1) {\n      page.value -= 1;\n      await loadArticles();\n      return;\n    }\n\n    items.value = items.value.filter((item) => item.id !== article.id);\n    total.value = Math.max(0, total.value - 1);\n  } catch (error) {\n    errorMessage.value = error instanceof Error ? error.message : '删除文章失败，请稍后重试。';\n  } finally {\n    busyId.value = null;\n  }\n}\n\nwatch([page, keyword, status, categoryId], async () => {\n  await loadArticles();\n});\n\nonMounted(async () => {\n  await loadArticles();\n});\n</script>\n\n<template>\n  <div class=\"space-y-6\">\n    <AdminPageHeader\n      title=\"文章管理\"\n      description=\"在这里浏览真实文章数据，按关键词、状态和分类筛选，并进入编辑或删除。\"\n    >\n      <template #actions>\n        <NuxtLink class=\"admin-button-primary\" :to=\"adminPaths.articleCreate\">新建文章</NuxtLink>\n      </template>\n    </AdminPageHeader>\n\n    <div class=\"rounded-lg border border-[var(--admin-border)] bg-white p-4\">\n      <div class=\"flex flex-col gap-3 xl:flex-row xl:items-center xl:justify-between\">\n        <AdminSearchField\n          v-model=\"keyword\"\n          placeholder=\"搜索标题或摘要\"\n          @update:modelValue=\"page = 1\"\n        />\n\n        <div class=\"flex flex-wrap gap-2\">\n          <select v-model=\"status\" class=\"admin-select w-auto min-w-36\" @change=\"page = 1\">\n            <option value=\"all\">全部状态</option>\n            <option value=\"published\">已发布</option>\n            <option value=\"draft\">草稿</option>\n          </select>\n\n          <select v-model=\"categoryId\" class=\"admin-select w-auto min-w-40\" @change=\"page = 1\">\n            <option value=\"all\">全部分类</option>\n            <option v-for=\"item in options.categories\" :key=\"item.id\" :value=\"item.id\">\n              {{ item.name }}\n            </option>\n          </select>\n        </div>\n      </div>\n    </div>\n\n    <div\n      v-if=\"errorMessage\"\n      class=\"admin-card border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-600\"\n    >\n      {{ errorMessage }}\n    </div>\n\n    <div class=\"admin-card overflow-hidden\">\n      <div class=\"overflow-x-auto\">\n        <table class=\"w-full border-collapse\">\n          <thead>\n            <tr class=\"border-b border-[var(--admin-border)] bg-slate-50/90 text-left\">\n              <th\n                v-for=\"label in ['文章', '分类', '状态', '发布时间', '更新时间', '操作']\"\n                :key=\"label\"\n                class=\"px-5 py-4 text-xs font-semibold uppercase tracking-[0.14em] text-slate-400\"\n              >\n                {{ label }}\n              </th>\n            </tr>\n          </thead>\n          <tbody>\n            <tr v-if=\"loading\">\n              <td class=\"px-5 py-10 text-sm text-slate-400\" colspan=\"6\">\n                正在加载文章数据...\n              </td>\n            </tr>\n\n            <tr v-else-if=\"items.length === 0\">\n              <td class=\"px-5 py-10 text-sm text-slate-400\" colspan=\"6\">\n                当前筛选条件下还没有文章。\n              </td>\n            </tr>\n\n            <template v-else>\n              <tr\n                v-for=\"article in items\"\n                :key=\"article.id\"\n                class=\"border-b border-[var(--admin-border)] transition hover:bg-slate-50\"\n              >\n                <td class=\"px-5 py-4\">\n                  <div class=\"flex min-w-[260px] items-center gap-4\">\n                    <img\n                      v-if=\"article.coverImageUrl\"\n                      class=\"h-14 w-14 rounded-[4px] object-cover\"\n                      :src=\"article.coverImageUrl\"\n                      :alt=\"article.title\"\n                    />\n                    <div\n                      v-else\n                      class=\"flex h-14 w-14 items-center justify-center rounded-[4px] bg-slate-100 text-xs text-slate-400\"\n                    >\n                      无封面\n                    </div>\n\n                    <div class=\"min-w-0\">\n                      <p class=\"truncate text-sm font-semibold text-slate-900\">{{ article.title }}</p>\n                      <p class=\"mt-1 line-clamp-2 text-sm leading-6 text-slate-500\">{{ article.excerpt }}</p>\n                    </div>\n                  </div>\n                </td>\n\n                <td class=\"px-5 py-4 text-sm text-slate-600\">\n                  {{\n                    article.categories && article.categories.length > 0\n                      ? article.categories.map((cat) => cat.name).join(', ')\n                      : '未分类'\n                  }}\n                </td>\n\n                <td class=\"px-5 py-4\">\n                  <AdminStatusBadge :tone=\"article.status === 'published' ? 'success' : 'warning'\">\n                    {{ article.status === 'published' ? '已发布' : '草稿' }}\n                  </AdminStatusBadge>\n                </td>\n\n                <td class=\"px-5 py-4 text-sm text-slate-600\">\n                  {{ article.publishedAt ? formatAdminDate(article.publishedAt) : '未发布' }}\n                </td>\n\n                <td class=\"px-5 py-4 text-sm text-slate-600\">{{ formatAdminDate(article.updatedAt) }}</td>\n\n                <td class=\"px-5 py-4\">\n                  <div class=\"flex flex-wrap gap-2\">\n                    <NuxtLink\n                      class=\"admin-button-secondary\"\n                      :to=\"`/articles/${article.slug}`\"\n                      target=\"_blank\"\n                    >\n                      预览\n                    </NuxtLink>\n                    <NuxtLink class=\"admin-button-secondary\" :to=\"adminPaths.articleEdit(article.id)\">\n                      编辑\n                    </NuxtLink>\n                    <button\n                      class=\"admin-button-danger\"\n                      type=\"button\"\n                      :disabled=\"busyId === article.id\"\n                      @click=\"handleDelete(article)\"\n                    >\n                      {{ busyId === article.id ? '删除中...' : '删除' }}\n                    </button>\n                  </div>\n                </td>\n              </tr>\n            </template>\n          </tbody>\n        </table>\n      </div>\n\n      <AdminPagination\n        :page=\"Math.min(page, totalPages)\"\n        :total=\"total\"\n        :total-pages=\"totalPages\"\n        label=\"篇文章\"\n        @update:page=\"page = $event\"\n      />\n    </div>\n  </div>\n</template>\n"],"version":3}